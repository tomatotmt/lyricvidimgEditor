{
  "name": "lyricvidimg-editor",
  "version": "1.0.0",
  "description": "Lyric-first MV editor with image, beat, and text effects.",
  "main": "electron/lrc-sync-main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomatotmt/lyricvidimgEditor.git"
  },
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@remotion/animated-emoji": "4.0.471",
    "@remotion/animation-utils": "4.0.471",
    "@remotion/bundler": "4.0.471",
    "@remotion/cli": "4.0.471",
    "@remotion/cloudrun": "4.0.471",
    "@remotion/enable-scss": "4.0.471",
    "@remotion/fonts": "4.0.471",
    "@remotion/gif": "4.0.471",
    "@remotion/google-fonts": "4.0.471",
    "@remotion/lambda": "4.0.471",
    "@remotion/lottie": "4.0.471",
    "@remotion/media-utils": "4.0.471",
    "@remotion/noise": "4.0.471",
    "@remotion/paths": "4.0.471",
    "@remotion/player": "4.0.471",
    "@remotion/renderer": "4.0.471",
    "@remotion/shapes": "4.0.471",
    "@remotion/skia": "4.0.471",
    "@remotion/studio": "4.0.471",
    "@remotion/tailwind-v4": "4.0.471",
    "@remotion/three": "4.0.471",
    "@remotion/whisper-web": "4.0.471",
    "@remotion/zod-types": "4.0.471",
    "@types/three": "^0.173.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.471",
    "tailwindcss": "4.0.0",
    "three": "^0.173.0",
    "vite": "^8.0.16",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.409",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/web": "0.0.166",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "prettier": "3.6.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "web": "node scripts/dev-server.mjs",
    "vite": "vite",
    "build": "vite build",
    "build:lrc-web": "vite build --config vite.lrc-sync.config.ts",
    "preview:lrc-app": "npm run build:lrc-web && node scripts/preview-lrc-sync-app.mjs",
    "build:lrc-app": "npm run build:lrc-web && node scripts/package-lrc-sync-app.mjs",
    "build:lrc-installer": "npm run build:lrc-web && electron-builder --config electron-builder.lrc.cjs",
    "build:lrc-mac": "npm run build:lrc-web && electron-builder --config electron-builder.lrc.cjs --mac",
    "build:lrc-mac-zip": "npm run build:lrc-web && electron-builder --config electron-builder.lrc.cjs --mac zip",
    "build:editor-mac": "npm run build && electron-builder --config electron-builder.editor.cjs --mac zip --publish never",
    "build:editor-win": "npm run build && electron-builder --config electron-builder.editor.cjs --win zip --publish never",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
